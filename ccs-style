body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 0;
}

header, footer {
  background: #333;
  color: white;
  text-align: center;
  padding: 1em;
}

nav ul {
  display: flex;
  justify-content: center;
  list-style: none;
  padding: 0;
}

nav ul li {
  margin: 0 1em;
}

main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

section {
  margin: 2em 0;
  width: 80%;
}
